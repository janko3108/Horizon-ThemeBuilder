{%- doc -%}
  Renders the customer-facing "products per row" picker (Filippa K style).
  Desktop offers 3 / 4 / 6 columns, mobile offers 1 / 2 / 3. Reuses the grid
  view mechanism: each radio sets `product-grid-view` on the grid (to cols-N)
  via results-list/updateLayout, persisted per viewport in sessionStorage and
  restored by the script in product-grid.liquid.

  @param {string} viewport - 'mobile' or 'desktop'.
  @param {string} [default_cols] - The merchant default column count for this viewport (initial selection).

  @example
  {% render 'grid-density-controls', viewport: 'desktop', default_cols: section.settings.columns_desktop %}
{%- enddoc -%}

{%- liquid
  if viewport == 'mobile'
    assign counts = '1,2,3' | split: ','
    assign radio_name = 'grid-mobile'
    assign default_cols = default_cols | default: '2'
  else
    assign counts = '3,4,6' | split: ','
    assign radio_name = 'grid'
    assign default_cols = default_cols | default: '4'
  endif
-%}

<div class="column-options-wrapper">
  <fieldset class="column-options">
    <legend class="column-options__legend visually-hidden">
      {{ 'content.grid_view.grid_fieldset' | t }}
    </legend>

    {%- for n in counts -%}
      {%- assign n_int = n | plus: 0 -%}
      <label class="column-options__option column-options__option--{{ viewport }}">
        <input
          type="radio"
          name="{{ radio_name }}"
          value="cols-{{ n }}"
          class="column-options__option-input"
          {% if n == default_cols %}checked{% endif %}
          aria-label="{{ n }}"
          on:change="results-list/updateLayout"
          data-skip-node-update
        >
        <span class="column-picker column-picker--cols-{{ n }}" aria-hidden="true">
          {%- for i in (1..n_int) -%}<span class="column-picker__bar"></span>{%- endfor -%}
        </span>
      </label>
    {%- endfor -%}
  </fieldset>
</div>

{% stylesheet %}
  .column-options-wrapper {
    --icon-offset: -3px;

    display: flex;
    gap: var(--gap-sm);
    min-width: fit-content;
    justify-content: flex-end;
    height: var(--minimum-touch-target);
    align-items: center;
    margin-right: var(--icon-offset);
  }

  .column-options-wrapper:only-child {
    margin-left: auto;
  }

  .facets__form-wrapper > .column-options-wrapper:first-child {
    margin-left: auto;
  }

  .facets .column-options-wrapper {
    display: none;

    @media screen and (min-width: 750px) {
      display: flex;
    }
  }

  .column-options {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--gap-xs);
    margin: 0;
    padding: 0;
    border: none;

    @media screen and (min-width: 750px) {
      gap: var(--gap-2xs);
    }
  }

  .column-options__legend {
    padding: 0;
    margin: 0;
  }

  /* Show only this viewport's options. */
  .column-options__option {
    display: none;
    position: relative;
  }
  .column-options__option--mobile {
    @media screen and (max-width: 749px) {
      display: flex;
    }
  }
  .column-options__option--desktop {
    @media screen and (min-width: 750px) {
      display: flex;
    }
  }

  .column-options__option-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    margin: 0;
    padding: 0;
    width: auto;
    height: auto;
    aspect-ratio: unset;
    border: none;
    border-radius: 0;
    background: transparent;
    appearance: auto;
    display: block;
    cursor: pointer;
  }

  /* Column-count icon: N thin vertical bars representing the columns. */
  .column-picker {
    display: flex;
    align-items: center;
    gap: 2px;
    height: 14px;
    padding: var(--padding-2xs);
    border-radius: var(--style-border-radius-xs);
    color: rgb(var(--color-rgb, var(--color-foreground-rgb)) / var(--opacity-50));
    transition: background-color var(--animation-speed) ease, color var(--animation-speed) ease;
  }

  .column-picker__bar {
    width: 2.5px;
    height: 100%;
    border-radius: 1px;
    background: currentColor;
  }

  .column-options__option:hover .column-picker {
    background-color: rgb(var(--color-foreground-rgb) / var(--opacity-5));
  }

  .column-options__option-input:checked ~ .column-picker {
    color: rgb(var(--color-rgb, var(--color-foreground-rgb)));
    background-color: rgb(var(--color-foreground-rgb) / var(--opacity-5));
  }
{% endstylesheet %}
