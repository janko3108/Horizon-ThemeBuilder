{%- doc -%}
  Cart rewards / free-shipping progress bar for the cart drawer.

  Shows progress toward up to three spend thresholds (e.g. free shipping + gifts),
  a dynamic "[amount] away from [reward]" message, and milestone icons that fill in
  as each threshold is reached. Everything is configurable in Theme settings →
  Cart → Rewards bar.

  Computed entirely server-side from `cart.total_price`, so it refreshes whenever
  the cart drawer re-renders (add / remove / quantity change) — no JS required.
{%- enddoc -%}

{%- if settings.cart_rewards_enabled -%}
  {%- liquid
    assign total = cart.total_price

    # Highest configured threshold defines the end of the bar; also count tiers.
    assign max_amount = 0
    assign tier_count = 0
    for i in (1..3)
      assign amt_key = 'cart_reward_' | append: i | append: '_amount'
      assign amt = settings[amt_key]
      if amt > 0
        assign tier_count = tier_count | plus: 1
        assign amt_cents = amt | times: 100
        if amt_cents > max_amount
          assign max_amount = amt_cents
        endif
      endif
    endfor
  -%}

  {%- if tier_count > 0 and max_amount > 0 -%}
    {%- liquid
      # Fill: how far (0–100%) the cart total is toward the top threshold.
      assign progress_pct = total | times: 100 | divided_by: max_amount
      if progress_pct > 100
        assign progress_pct = 100
      endif

      # The first not-yet-reached tier (in order) drives the message.
      assign next_amount = 0
      assign next_label = ''
      for i in (1..3)
        assign amt_key = 'cart_reward_' | append: i | append: '_amount'
        assign amt = settings[amt_key]
        if amt > 0
          assign amt_cents = amt | times: 100
          if total < amt_cents
            if next_amount == 0 or amt_cents < next_amount
              assign next_amount = amt_cents
              assign label_key = 'cart_reward_' | append: i | append: '_label'
              assign next_label = settings[label_key]
            endif
          endif
        endif
      endfor

      if next_amount == 0
        assign message = settings.cart_rewards_success_text
      else
        assign remaining = next_amount | minus: total | money
        assign message = settings.cart_rewards_progress_text | replace: '[amount]', remaining | replace: '[reward]', next_label
      endif
    -%}

    <div
      class="cart-rewards"
      style="
        --cart-rewards-fill: {{ settings.cart_rewards_bar_fill }};
        --cart-rewards-track: {{ settings.cart_rewards_bar_track }};
        --cart-rewards-text: {{ settings.cart_rewards_text_color }};
        --cart-rewards-icon-on: {{ settings.cart_rewards_icon_on_color }};
        --cart-rewards-icon-off: {{ settings.cart_rewards_icon_off_color }};
      "
    >
      {%- if message != blank -%}
        <p class="cart-rewards__message">{{ message }}</p>
      {%- endif -%}

      <div class="cart-rewards__bar">
        <div class="cart-rewards__track">
          <div class="cart-rewards__fill" style="width: {{ progress_pct }}%;"></div>
          {%- for i in (1..3) -%}
            {%- liquid
              assign amt_key = 'cart_reward_' | append: i | append: '_amount'
              assign amt = settings[amt_key]
            -%}
            {%- if amt > 0 -%}
              {%- liquid
                assign amt_cents = amt | times: 100
                assign pos = amt_cents | times: 100 | divided_by: max_amount
                assign label_key = 'cart_reward_' | append: i | append: '_label'
                assign icon_key = 'cart_reward_' | append: i | append: '_icon'
                assign tier_label = settings[label_key]
                assign tier_icon = settings[icon_key]
                assign reached = false
                if total >= amt_cents
                  assign reached = true
                endif
                # Keep edge labels inside the bar: align the first label left and the
                # last label right so they can't overflow the drawer.
                assign label_align = 'center'
                if pos <= 20
                  assign label_align = 'start'
                elsif pos >= 80
                  assign label_align = 'end'
                endif
              -%}
              <div
                class="cart-rewards__milestone cart-rewards__milestone--label-{{ label_align }}{% if reached %} is-reached{% endif %}"
                style="left: {{ pos }}%;"
              >
                <span class="cart-rewards__icon">
                  {%- case tier_icon -%}
                    {%- when 'truck' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 3.75h14.5v10.5H1zM15.5 7.5H19l3.5 3.5v3.25h-7z"/><circle cx="5.5" cy="18" r="2"/><circle cx="18" cy="18" r="2"/></svg>
                    {%- when 'star' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2.5 15 8.6 21.8 9.6 16.9 14.4 18 21.2 12 18 6 21.2 7.1 14.4 2.2 9.6 9 8.6 12 2.5"/></svg>
                    {%- when 'heart' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1.1-1.1a5.5 5.5 0 1 0-7.8 7.8L12 21.2l8.8-8.8a5.5 5.5 0 0 0 0-7.8z"/></svg>
                    {%- when 'percent' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 12 20 21.5 4 21.5 4 12"/><rect x="2.5" y="7" width="19" height="5" rx="0.5"/><line x1="12" y1="21.5" x2="12" y2="7"/><path d="M12 7H7.6a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.4a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                  {%- endcase -%}
                </span>
                {%- if tier_label != blank -%}
                  <span class="cart-rewards__label">{{ tier_label }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

{% stylesheet %}
  .cart-rewards {
    padding: var(--padding-lg) var(--padding-lg) calc(var(--padding-lg) + 18px);
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    /* Safety: never let a milestone label cause horizontal scroll in the drawer. */
    overflow: hidden;
  }

  .cart-rewards__message {
    margin: 0 0 20px;
    text-align: center;
    font-size: 0.85rem;
    line-height: 1.4;
    color: var(--cart-rewards-text, var(--color-foreground));
  }

  .cart-rewards__bar {
    position: relative;
    padding-inline: 16px;
  }

  .cart-rewards__track {
    position: relative;
    height: 4px;
    border-radius: 999px;
    background: var(--cart-rewards-track, #e7e7e7);
  }

  .cart-rewards__fill {
    position: absolute;
    inset-block: 0;
    left: 0;
    min-width: 4px;
    border-radius: 999px;
    background: var(--cart-rewards-fill, #1a1a1a);
    transition: width 0.4s var(--animation-easing, ease);
  }

  .cart-rewards__milestone {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cart-rewards__icon {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--cart-rewards-track, #e7e7e7);
    color: var(--cart-rewards-icon-off, #9b9b9b);
    border: 2px solid var(--color-background);
    transition: background 0.3s var(--animation-easing, ease), color 0.3s var(--animation-easing, ease);
  }

  .cart-rewards__icon svg {
    width: 16px;
    height: 16px;
  }

  .cart-rewards__milestone.is-reached .cart-rewards__icon {
    background: var(--cart-rewards-fill, #1a1a1a);
    color: var(--cart-rewards-icon-on, #fff);
  }

  .cart-rewards__label {
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    max-width: 33vw;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 0.6rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--cart-rewards-text, var(--color-foreground));
  }

  /* First / last milestone labels align to their edge so they stay in bounds. */
  .cart-rewards__milestone--label-start .cart-rewards__label {
    left: 0;
    right: auto;
    transform: none;
    text-align: left;
  }

  .cart-rewards__milestone--label-end .cart-rewards__label {
    left: auto;
    right: 0;
    transform: none;
    text-align: right;
  }

  /* Empty cart: pin the rewards bar to the top, then vertically centre the empty
     message in the space beneath it (so it sits in the middle of the drawer
     rather than crammed under the bar). */
  .cart-drawer--empty .cart-drawer__content:has(.cart-rewards) {
    justify-content: flex-start;
    align-items: stretch;
  }

  .cart-drawer__content:has(.cart-rewards) .cart-drawer__empty-inner {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }
{% endstylesheet %}
