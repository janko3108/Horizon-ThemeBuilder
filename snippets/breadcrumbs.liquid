{%- doc -%}
  Filippa K–style breadcrumb trail for collection (PLP) and product (PDP) pages.

  - Collection: Home / {collection title}
  - Product:    Home / {collection} / {product title}
    (collection = the one the product was viewed through, else its first collection)

  Renders nothing on other templates, or when there's nothing meaningful to show.

  @example
  {% render 'breadcrumbs' %}
{%- enddoc -%}

{%- liquid
  assign show = false
  if template.name == 'collection' and collection != blank
    assign show = true
  elsif template.name == 'product' and product != blank
    assign show = true
  endif
-%}

{%- if show -%}
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol class="breadcrumbs__list" role="list">
      <li class="breadcrumbs__item">
        <a class="breadcrumbs__link" href="{{ routes.root_url }}">Home</a>
      </li>

      {%- if template.name == 'product' -%}
        {%- liquid
          assign crumb_collection = blank
          if collection != blank
            assign crumb_collection = collection
          elsif product.collections.size > 0
            assign crumb_collection = product.collections.first
          endif
        -%}
        {%- if crumb_collection != blank -%}
          <li class="breadcrumbs__item">
            <a class="breadcrumbs__link" href="{{ crumb_collection.url }}">{{ crumb_collection.title }}</a>
          </li>
        {%- endif -%}
        <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">
          <span>{{ product.title }}</span>
        </li>

      {%- elsif template.name == 'collection' -%}
        <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">
          <span>{{ collection.title }}</span>
        </li>
      {%- endif -%}
    </ol>
  </nav>
{%- endif -%}

{% stylesheet %}
  .breadcrumbs {
    font-size: 0.8125rem;
    line-height: 1.2;
    padding-block: var(--padding-sm, 12px);
    padding-inline: var(--page-margin, var(--sidebar-padding, 20px));
  }

  .breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs__item {
    display: inline-flex;
    align-items: center;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.5);
    white-space: nowrap;
  }

  /* "/" separator between crumbs */
  .breadcrumbs__item:not(:last-child)::after {
    content: "/";
    margin-inline: 0.55em;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.35);
  }

  .breadcrumbs__link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumbs__link:hover {
    color: var(--color-foreground);
  }

  /* current page — darker, like FK */
  .breadcrumbs__item--current {
    color: var(--color-foreground);
  }

  /* keep long product names from overflowing the row on mobile */
  @media screen and (max-width: 749px) {
    .breadcrumbs__item--current {
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .breadcrumbs__item--current span {
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }
{% endstylesheet %}
