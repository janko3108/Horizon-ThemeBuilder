{%- doc -%}
  Filippa K–style breadcrumb trail for collection (PLP) and product (PDP) pages.

  - Collection: Home / {collection title}
  - Product:    Home / {collection} / {product title}
    (collection = the one the product was viewed through, else its first collection)

  Renders nothing on other templates, or when there's nothing meaningful to show.

  @example
  {% render 'breadcrumbs' %}
{%- enddoc -%}

{%- liquid
  assign show = false
  if settings.show_breadcrumbs != false
    if template.name == 'collection' and collection != blank
      assign show = true
    elsif template.name == 'product' and product != blank
      assign show = true
    endif
  endif
-%}

{%- if show -%}
  <nav class="breadcrumbs{% if overlay %} breadcrumbs--overlay{% endif %}{% if in_details %} breadcrumbs--details{% endif %}" aria-label="Breadcrumb" style="--breadcrumbs-font-size: {{ settings.breadcrumbs_font_size | default: 13 }}px;">
    <ol class="breadcrumbs__list" role="list">
      <li class="breadcrumbs__item">
        <a class="breadcrumbs__link" href="{{ routes.root_url }}">Home</a>
      </li>

      {%- if template.name == 'product' -%}
        {%- liquid
          assign crumb_collection = blank
          if collection != blank
            assign crumb_collection = collection
          elsif product.collections.size > 0
            assign crumb_collection = product.collections.first
          endif
        -%}
        {%- if crumb_collection != blank -%}
          <li class="breadcrumbs__item">
            <a class="breadcrumbs__link" href="{{ crumb_collection.url }}">{{ crumb_collection.title }}</a>
          </li>
        {%- endif -%}
        <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">
          <span>{{ product.title }}</span>
        </li>

      {%- elsif template.name == 'collection' -%}
        <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">
          <span>{{ collection.title }}</span>
        </li>
      {%- endif -%}
    </ol>
  </nav>
{%- endif -%}

{% stylesheet %}
  .breadcrumbs {
    font-size: var(--breadcrumbs-font-size, 0.8125rem);
    line-height: 1.2;
    padding-block: var(--padding-sm, 12px);
    padding-inline: var(--page-margin, var(--sidebar-padding, 20px));
  }

  .breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs__item {
    display: inline-flex;
    align-items: center;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.5);
    white-space: nowrap;
  }

  /* "/" separator between crumbs */
  .breadcrumbs__item:not(:last-child)::after {
    content: "/";
    margin-inline: 0.55em;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.35);
  }

  .breadcrumbs__link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumbs__link:hover {
    color: var(--color-foreground);
  }

  /* current page — darker, like FK */
  .breadcrumbs__item--current {
    color: var(--color-foreground);
  }

  /* keep long product names from overflowing the row on mobile */
  @media screen and (max-width: 749px) {
    .breadcrumbs__item--current {
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .breadcrumbs__item--current span {
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }

  /* ---- PDP variant ----
     Rendered as the LAST child of .product-information__media so it can be:
     - Mobile: in normal flow -> sits below the gallery, above the details group.
     - Desktop: absolutely positioned to overlay the media's top-left, under the
       header (Filippa K placement). */
  /* Mobile: use the in-details copy (sits in the product details group, above the
     title, so it scrolls with the details and isn't overlapped by the sticky
     gallery). Hide the media-overlay copy. */
  @media screen and (max-width: 749px) {
    .breadcrumbs--overlay {
      display: none;
    }
    .breadcrumbs--details {
      padding-block: 0 var(--padding-sm, 0.75rem);
      padding-inline: 0;
    }
  }

  /* Desktop: overlay the media's top-left, under the header. Hide the in-details
     copy. */
  @media screen and (min-width: 750px) {
    .breadcrumbs--details {
      display: none;
    }
    .product-information__media {
      position: relative;
    }
    .breadcrumbs--overlay {
      position: absolute;
      z-index: 2;
      top: calc(var(--header-group-height, 88px) + 0.5rem);
      inset-inline-start: var(--page-margin, 2.5rem);
      padding: 0;
      max-width: calc(100% - 2 * var(--page-margin, 2.5rem));
    }
  }
{% endstylesheet %}
