{% doc %}
  Filippa K–style Cart / Wishlist tab switcher, shown in the cart drawer's cart
  panel header and in the wishlist panel header (both live inside the single cart
  drawer — see snippets/cart-drawer.liquid + snippets/wishlist-drawer-panel.liquid).

  Switching is IN PLACE: each tab carries `data-drawer-tab`, and wishlist.js sets
  `data-active-tab` on the cart dialog to crossfade between the stacked cart and
  wishlist panels. The drawer itself never closes or slides — exactly like FK.

  Renders nothing unless the setting is on AND the cart is in drawer mode, so
  callers can use it as a drop-in replacement for the drawer title.

  @param {string} active - 'cart' or 'wishlist' (which panel this header belongs to)
{% enddoc %}
{%- if settings.wishlist_enabled != false and settings.wishlist_show_cart_tabs and settings.cart_type == 'drawer' -%}
  <div class="drawer-tabs" role="tablist">
    <button
      type="button"
      class="drawer-tab{% if active == 'cart' %} is-active{% endif %}"
      data-drawer-tab="cart"
      role="tab"
      aria-selected="{% if active == 'cart' %}true{% else %}false{% endif %}"
    >
      {{ 'content.cart_title' | t }}<span class="drawer-tab__count" data-cart-count>{% if cart.item_count > 0 %}({{ cart.item_count }}){% endif %}</span>
    </button>
    <button
      type="button"
      class="drawer-tab{% if active == 'wishlist' %} is-active{% endif %}"
      data-drawer-tab="wishlist"
      role="tab"
      aria-selected="{% if active == 'wishlist' %}true{% else %}false{% endif %}"
    >
      Wishlist<span class="drawer-tab__count wishlist-count"></span>
    </button>
  </div>
{%- endif -%}
