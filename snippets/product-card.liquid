{%- doc -%}
  This snippet is used to render a product card.
  It is used in the product block, featured product block, and the product card block.
  The product object is null or when placeholders are rendered.

  @param {object} product - The product object
  @param {object} children - The children of the product card
  @param {object} [block] - The block object
  @param {number} [product_card_gap] - The gap between the product card children (overrides block settings)
  @param {string} [product_view_context] - The context in which the product card is being rendered. Used for standard events.
{%- enddoc -%}

{% assign block_settings = block.settings %}

{% style %}
  {% if request.visual_preview_mode %}
    product-card[data-product-transition] {
      width: 100%;
      min-width: 250px;
    }
  {% endif %}
{% endstyle %}

{% liquid
  assign has_quick_add = false
  if settings.quick_add and product.available
    assign has_quick_add = true
  endif

  assign has_mobile_quick_add = false
  if has_quick_add and settings.mobile_quick_add
    assign has_mobile_quick_add = true
  endif

  assign product_card_id = 'product-card-link-' | append: block.id | append: '-' | append: product.id
  assign product_card_gap_value = product_card_gap | default: block_settings.product_card_gap

  # Logic to determine which variant URL to use (matching swatch selection logic)
  assign variant_to_link = product.selected_or_first_available_variant

  if settings.transition_to_main_product
    assign featured_image = variant_to_link.featured_image
    if featured_image == blank
      assign featured_image = product.featured_media.preview_image
    endif

    if featured_image != blank
      assign featured_media_url = featured_image | image_url: width: 500
    endif
  endif

  assign onboarding = false
  if product.id == empty or product == blank
    assign onboarding = true
  endif

  if block_settings.background_color != blank
    render 'contrast-override', background_color: block_settings.background_color, text_color: block_settings.text_color, section_id: block.id
  endif
%}

<product-card
  class="product-card size-style"
  style="{% render 'size-style', settings: block_settings %}"
  data-product-id="{{ product.id }}"
  id="product-card-{{ block.id }}"
  {% if settings.transition_to_main_product %}
    data-product-transition="true"
    data-featured-media-url="{{ featured_media_url }}"
    on:click="/handleViewTransition"
  {% endif %}
  {{ block.shopify_attributes }}
  {% if onboarding %}
    data-placeholder="true"
  {% endif %}
  {%- unless onboarding -%}
    {% # theme-check-disable-next-line UnknownFilter %}
    view-event-payload="{{ product | standard_event_data: 'view', context: product_view_context | escape }}"
  {%- endunless -%}
>
  <a
    id="{{ product_card_id | md5 }}"
    {% unless onboarding %}
      href="{{ variant_to_link.url }}"
    {% endunless %}
    class="product-card__link"
    ref="productCardLink"
  >
    <span class="visually-hidden">
      {{ product.title }}
    </span>
  </a>
  <div
    class="
      product-card__content
      layout-panel-flex
      layout-panel-flex--column
      product-grid__card
      spacing-style
      border-style
      gap-style
      {% if block_settings.background_color != blank %} color-custom-{{ block.id }}{% endif %}
    "
    style="
      {% render 'border-override', settings: block_settings %}
      {% render 'layout-panel-style', settings: block_settings %}
      {% render 'spacing-style', settings: block_settings %}
      {% render 'gap-style', value: product_card_gap_value, name: 'product-card-gap' %}
      --product-card-overlay-inset: {{ settings.product_card_overlay_inset | default: 8 }}px;
      --quick-add-display: {% if has_quick_add %}flex{% else %}none{% endif %};
      --quick-add-mobile-display: {% if has_mobile_quick_add %}flex{% else %}none{% endif %};
      --quick-add-mobile-opacity: {% if has_mobile_quick_add %}1{% else %}0{% endif %};
      {% if block_settings.padding-inline-start > 0 %}--zoom-out-padding-inline-start: min(var(--padding-xs), {{ block_settings.padding-inline-start | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-inline-end > 0 %}--zoom-out-padding-inline-end: min(var(--padding-xs), {{ block_settings.padding-inline-end | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-block-start > 0 %}--zoom-out-padding-block-start: min(var(--padding-xs), {{ block_settings.padding-block-start | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-block-end > 0 %}--zoom-out-padding-block-end: min(var(--padding-xs), {{ block_settings.padding-block-end | times: 0.7}}px);{% endif %}
    "
  >
    {{ children }}
    {%- comment -%}
      Universal colour swatches (Theme settings → Product cards). Uses the same
      <product-swatches> component as the Swatches block so they align, space and
      swap the card image exactly like the block version.
    {%- endcomment -%}
    {%- liquid
      # Skip the universal swatches when the card already includes a Swatches
      # block (its rendered output is in `children`) — avoids duplicate rows.
      assign has_swatches_block = false
      if children contains 'product-swatches'
        assign has_swatches_block = true
      endif
      assign product_has_swatches = false
      for product_option in product.options_with_values
        assign swatch_count = product_option.values | map: 'swatch' | compact | size
        if swatch_count > 0
          assign product_has_swatches = true
        endif
      endfor
    -%}
    {%- if settings.product_card_show_swatches and onboarding != true and product != blank and has_swatches_block == false -%}
      {%- if product_has_swatches -%}
        <product-swatches
          class="product-card__swatches"
          data-product-id="{{ product.id }}"
          data-product-url="{{ product.url }}"
          style="
            --overflow-list-alignment: flex-start;
            --overflow-list-alignment-mobile: flex-start;
            --product-swatches-alignment: start;
            --product-swatches-alignment-mobile: start;
            --product-swatches-padding-block-start: 10px;
            --product-swatches-padding-block-end: 0px;
            --product-swatches-padding-inline-start: {{ settings.product_card_swatch_inline_padding | default: 10 }}px;
            --product-swatches-padding-inline-end: 0px;
          "
        >
          {% render 'variant-swatches', product_resource: product %}
        </product-swatches>
      {%- endif -%}
    {%- endif -%}

    {%- comment -%}
      Card-level Quick Add (Adanola): a static button under the price instead of
      a hover overlay on the image. Rendered here (not in the gallery) so it sits
      with the title/price. Gated on section_id so it only appears where the
      caller provides one (product card / recommendations grid).
    {%- endcomment -%}
    {%- liquid
      assign show_card_quick_add = false
      if section_id != blank and onboarding != true and product != blank
        if settings.quick_add or settings.mobile_quick_add
          assign show_card_quick_add = true
        endif
      endif
    -%}
    {%- if show_card_quick_add -%}
      <div class="product-card__quick-add">
        {% render 'quick-add', product: product, section_id: section_id, block: block %}
      </div>
    {%- endif -%}
  </div>
</product-card>

{% stylesheet %}
  /* Adanola-style card hierarchy: colour swatches sit directly under the product
     image, above the title/price. The card content is a flex column, so we
     reorder: gallery first, swatches second, everything else (title, price,
     custom text, etc.) after. Robust to block configuration because all other
     children fall back to a later order. */
  .product-card__content > * {
    order: 3;
  }
  .product-card__content > .card-gallery {
    order: 1;
  }
  .product-card__content > .product-card__swatches {
    order: 2;
  }
  .product-card__content {
    position: relative;
  }

  /* Card-level Quick Add (Adanola): a compact button on the SAME row as the
     price (price left, button right). Absolutely anchored to the card's bottom
     edge so it lands on the price line (the price is the last in-flow line)
     without affecting layout. Overrides the absolute / hover / text-reveal
     styles from quick-add-styles.liquid (which assume the on-image overlay). */
  .product-card__quick-add {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 3;
    display: flex;
    justify-content: flex-end;
    padding-inline-end: var(--padding-sm);
    margin: 0;
    pointer-events: none;
  }
  .product-card__quick-add .quick-add {
    position: static;
    inset: auto;
    z-index: auto;
    width: auto;
    pointer-events: none;
  }
  .product-card__quick-add .quick-add__product-form-component {
    width: auto;
    height: auto;
  }
  .product-card__quick-add .shopify-product-form {
    display: flex;
    width: auto;
    height: auto;
    justify-content: flex-end;
    align-items: center;
  }
  .product-card__quick-add .quick-add__button {
    position: static;
    opacity: 1;
    width: auto;
    min-width: 0;
    height: var(--button-size-md);
    min-height: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding-inline: var(--padding-sm);
    border-radius: var(--product-corner-radius, 0);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    backdrop-filter: none;
    overflow: visible;
    pointer-events: auto;
  }
  .product-card__quick-add .quick-add__button .add-to-cart-text {
    width: auto;
    height: auto;
    display: flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border-radius: 0;
    overflow: visible;
  }
  /* Always show the button label (no hover-to-reveal animation). */
  .product-card__quick-add .quick-add__button .add-to-cart-text__content {
    grid-template-columns: 1fr;
  }
  .product-card__quick-add .quick-add__button .add-to-cart-text__content > span {
    min-width: 0;
  }
  .product-card__quick-add .quick-add__button .add-to-cart-text__content > span span {
    opacity: 1;
    filter: none;
    translate: none;
    padding: 0;
  }
  .product-card__quick-add .quick-add__button .add-to-cart-icon {
    width: 1.05em;
    height: 1.05em;
    flex: none;
  }
  .product-card__quick-add .quick-add__button .add-to-cart-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  /* Desktop: give the button room for its label. Mobile keeps it compact
     (icon-only) so it doesn't crowd the narrow 2-up cards. */
  @media screen and (min-width: 750px) {
    .product-card__quick-add .quick-add__button {
      min-width: 7rem;
    }
  }

  /* Universal colour swatches — mirror the Swatches block's card styling so the
     setting-driven swatches align and space exactly like the block version
     (these rules normally live on the block; duplicated here so they apply even
     when no Swatches block is present on the card). */
  product-swatches.product-card__swatches {
    width: 100%;
    display: flex;
    position: relative;
    overflow: hidden;
    gap: 0;
    flex-shrink: 0;
  }

  .product-card__swatches .variant-option {
    margin-inline: 0 var(--product-card-swatch-gap, 5px);
    padding: 0;
    border: 0;
    min-inline-size: 0;
  }

  .product-card product-swatches.product-card__swatches swatches-variant-picker-component {
    --overflow-list-padding-inline:
      var(--product-swatches-padding-inline-start)
      calc(var(--product-swatches-padding-inline-end) + var(--focus-outline-offset) + var(--focus-outline-width));
  }

  .product-card__placeholder-image svg {
    height: 100%;
  }

  .product-card__content slideshow-component {
    --cursor: pointer;
  }

  @media screen and (max-width: 749px) {
    .product-card slideshow-arrows .slideshow-control {
      display: none;
    }
  }
{% endstylesheet %}
