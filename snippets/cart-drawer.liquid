{% doc %}
  Renders reusable cart drawer markup for both initial page loads and Section Rendering API responses.

  @param {boolean} [render_wrapper] - When true, wraps the drawer in the section wrapper that the Section Rendering API adds automatically.
{% enddoc %}

{%- liquid
  assign render_wrapper = render_wrapper | default: true, allow_false: true
-%}

{%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
  {% if render_wrapper %}
    <div
      id="shopify-section-cart-drawer-section"
      class="shopify-section"
    >
  {% endif %}

  <script
    type="module"
    src="{{ 'cart-drawer.js' | asset_url }}"
    fetchpriority="low"
  ></script>

  {% capture empty_cart_drawer_content %}
    <div
      class="cart-drawer__content"
      aria-label="{{ 'accessibility.cart' | t }}"
    >
      {%- if settings.cart_rewards_enabled and settings.cart_rewards_show_when_empty -%}
        {% render 'cart-rewards-bar' %}
      {%- endif -%}
      <div class="cart-drawer__empty-inner">
        <h2
          class="theme-drawer__title h4"
          id="cart-drawer-heading"
        >
          {{ 'content.your_cart_is_empty' | t }}
        </h2>

        <div class="cart-drawer__items">
          {% render 'cart-products', force_empty: true, context: 'drawer' %}
        </div>
      </div>
    </div>
    {% endcapture %}

  <theme-drawer
    id="cart-drawer"
    data-skip-node-update
    overlay
    no-persist
  >
    <dialog
      ref="panel"
      class="theme-drawer__dialog color-custom-drawer"
      aria-labelledby="cart-drawer-heading"
      cart-summary-sticky="true"
      data-active-tab="cart"
    >
      <cart-drawer-component
        {% if settings.auto_open_cart_drawer and template.name != 'cart' %}
          auto-open
        {% endif %}
      >
        {% render 'cart-rewards-config' %}
        <template id="empty-cart-template">
          {{ empty_cart_drawer_content }}
        </template>

        <div
          class="cart-drawer__inner{% if cart.empty? %} cart-drawer--empty{% endif %}"
          data-hydration-key="cart-drawer-inner"
        >
          {%- if cart.empty? -%}
            <div class="theme-drawer__header">
              {%- render 'wishlist-cart-tabs', active: 'cart' -%}
              <button
                on:click="#cart-drawer/close"
                class="theme-drawer__close-button cart-drawer__close-button--empty"
                type="button"
                aria-label="{{ 'actions.close' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
          {%- else -%}
            {% capture cart_badge_html %}
              <span
                class="theme-drawer__badge{% if cart.item_count == 0 %} visually-hidden{% endif %}"
                aria-hidden="true"
                {% if cart.item_count <= 99 %}
                  data-maintain-ratio
                {% endif %}
              >
                {{- cart.item_count -}}
              </span>
              {% if cart.item_count > 0 %}
                <span class="visually-hidden">
                  {{ 'accessibility.cart_count' | t }}: {{ cart.item_count }}
                </span>
              {% endif %}
            {% endcapture %}
            {% assign cart_drawer_title = 'content.cart_title' | t %}
            {% render 'theme-drawer-header',
              title: cart_drawer_title,
              drawer_id: 'cart-drawer',
              heading_id: 'cart-drawer-heading',
              title_append: cart_badge_html
            %}
          {%- endif -%}

          {% capture cart_items_children %}
            {%- if cart.empty? -%}
              {{ empty_cart_drawer_content }}
            {%- else -%}
              <scroll-hint
                class="cart-drawer__content"
                aria-label="{{ 'accessibility.cart' | t }}"
              >
                {% render 'cart-rewards-bar' %}
                <scroll-hint class="cart-drawer__items">
                  {% render 'cart-products', context: 'drawer' %}
                </scroll-hint>

                <div class="cart-drawer__summary">
                  {%- if settings.cart_drawer_shipping_note != blank -%}
                    <p class="cart-fk-shipping-note">{{ settings.cart_drawer_shipping_note }}</p>
                  {%- endif -%}
                  {% render 'cart-summary', section_id: 'cart-drawer-section' %}
                  {%- if settings.cart_show_payment_icons -%}
                    {%- liquid
                      # Blank field => show the store's enabled payment methods automatically.
                      # Otherwise use the merchant's comma-separated list to pick AND order them.
                      if settings.cart_payment_icons != blank
                        assign cart_payment_icons = settings.cart_payment_icons | split: ','
                      else
                        assign cart_payment_icons = shop.enabled_payment_types
                      endif
                      assign cart_payment_align = 'flex-start'
                      if settings.cart_payment_icons_align == 'center'
                        assign cart_payment_align = 'center'
                      elsif settings.cart_payment_icons_align == 'right'
                        assign cart_payment_align = 'flex-end'
                      endif
                    -%}
                    {%- if cart_payment_icons.size > 0 -%}
                      <div class="cart-fk-payments" aria-hidden="true" style="justify-content: {{ cart_payment_align }};">
                        {%- for type in cart_payment_icons -%}
                          {{ type | strip | payment_type_svg_tag: class: 'cart-fk-payment-icon' }}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              </scroll-hint>
            {%- endif -%}
          {% endcapture %}
          {% render 'cart-items-component',
            children: cart_items_children,
            is_drawer: true,
            section_id: 'cart-drawer-section'
          %}
        </div>
      </cart-drawer-component>

      {%- comment -%}
        Unified Filippa K drawer: the wishlist panel lives inside the cart dialog as
        an absolute overlay. The Cart/Wishlist tabs crossfade between this and the
        cart content via the dialog's data-active-tab — the drawer never closes.
      {%- endcomment -%}
      {%- if settings.wishlist_enabled != false and settings.wishlist_show_cart_tabs -%}
        {%- render 'wishlist-drawer-panel', unified: true -%}
      {%- endif -%}
    </dialog>
  </theme-drawer>

  {% if render_wrapper %}
    </div>
  {% endif %}
{%- endif -%}

{% stylesheet %}
  cart-drawer-component {
    --cart-drawer-padding: var(--theme-drawer-padding);
    --font-paragraph--line-height: 1;
    display: contents;
  }

  .cart-drawer__inner {
    display: flex;
    flex-direction: column;
    /* Fill the dialog via flex-grow, not just height: 100%. The parent
       cart-drawer-component is display: contents, and percentage-height fill
       through it is unreliable across browsers — when it fails, the inner
       collapses to content height and the summary stops short of the bottom,
       leaving dead space beneath it. flex: 1 stretches it to the full 100dvh. */
    flex: 1;
    min-height: 0;
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__inner > .cart-items-component {
    flex: 1;
    min-height: 0;
    height: auto;
  }

  .cart-drawer__content {
    /* Fill the space below the header; the content area itself never scrolls —
       only the item list does. This prevents a spurious outer scrollbar. */
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    padding: 0;
    background-color: var(--color-background);
    overflow: hidden;
  }

  .cart-drawer__items {
    display: flex;
    flex-direction: column;
    padding-inline: var(--cart-drawer-padding);
    /* Breathing room so the first product isn't pressed up against the
       rewards bar's bottom border above it. */
    padding-block-start: var(--padding-lg);
    /* The single scroller: bounded by the flex layout so it only scrolls when
       the products genuinely overflow, leaving the header + summary pinned. */
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
  }

  .cart-drawer__items .cart-items__table-row {
    padding-bottom: var(--gap-xl);
    border-bottom: var(--style-border-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    margin-bottom: var(--gap-xl);
  }

  .cart-drawer__items .cart-items__table-row:has(+ .cart-items__nested-line) {
    border-bottom: none;
    margin-bottom: 0;
  }

  .cart-drawer__items .cart-items__table-row:last-child {
    border-bottom: none;
    padding-block-end: 0;
    margin-block-end: 0;
  }

  .cart-drawer__close-button--empty {
    margin-inline-start: auto;
  }

  .cart-drawer__summary {
    --cart-drawer-summary-padding: var(--padding-lg);

    position: sticky;
    bottom: 0;
    z-index: 1;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-xl);
    padding: var(--cart-drawer-summary-padding);
    /* Tighter bottom edge — the payment icons shouldn't have a big gap beneath
       them. Top/side padding stays at the larger --cart-drawer-summary-padding. */
    padding-block-end: var(--padding-md);
    margin-top: auto;
    background-color: var(--color-background);
    /* stylelint-disable-next-line color-named */
    mask-image: linear-gradient(to bottom, transparent, black var(--cart-drawer-summary-padding));

    @media screen and (min-width: 750px) {
      --cart-drawer-summary-padding: var(--padding-2xl);
    }
  }

  /* When the summary is too tall to pin (>50% of the drawer) it stops being
     sticky, but the item list stays the single scroller — the flex layout
     gives the summary its full height and the items the rest. Never give the
     content area its own overflow, so there can only ever be ONE scrollbar. */
  .theme-drawer__dialog[cart-summary-sticky='false'] .cart-drawer__summary {
    position: static;
    mask-image: none;
  }

  .cart-actions summary {
    padding-inline: 0;
    padding-block: var(--padding-sm);
    line-height: 1.2;
    min-height: var(--minimum-touch-target);
  }

  .cart-drawer__summary .cart__summary-totals:not(:has(.cart__subtotal-container:empty)) {
    border-block-start: var(--style-border-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    padding-block-start: var(--padding-2xl);
  }

  .cart-drawer__summary .cart-note {
    @media screen and (min-width: 750px) {
      margin-block-start: var(--margin-3xs);
    }
  }

  .cart-drawer--empty .cart-drawer__content {
    text-align: center;
    align-items: center;
    justify-content: center;
    min-height: auto;
  }

  .cart-drawer--empty .cart-drawer__items {
    padding-inline: 0;
    /* The loaded cart makes this the flex-grow scroller; in the empty state it's
       just a placeholder, so don't let it expand and shove the message around. */
    flex: 0 0 auto;
    padding-block-start: 0;
  }

  cart-drawer-component:not(:has(.cart-form)) .cart-drawer__content {
    text-align: center;
    align-items: center;
    justify-content: center;
  }

  cart-drawer-component:not(:has(.cart-form)) .cart-drawer__items {
    padding-inline: 0;
    flex: 0 0 auto;
    padding-block-start: 0;
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    html:active-view-transition-type(empty-cart-drawer) {
      .theme-drawer__close-button {
        view-transition-name: cart-drawer-close-button;
      }
    }
  }

  :active-view-transition {
    .cart-drawer__header,
    .cart-drawer__content {
      background: transparent;
    }
  }

  /* ---- Filippa K–style cart drawer footer ---- */
  .cart-fk-shipping-note {
    margin: 0 0 var(--padding-lg);
    font-size: 0.8125rem;
    line-height: 1.4;
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }

  .cart-fk-payments {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    /* Top spacing comes from the summary's flex gap (--gap-xl); the bottom gap
       is controlled by the summary's reduced padding-block-end. */
    margin-block: 0;
  }

  .cart-fk-payment-icon {
    width: 34px;
    height: 22px;
    border-radius: 3px;
  }

  /* FK-style count after the Cart/Wishlist tab label (e.g. "Cart (1)") */
  .drawer-tab__count:not(:empty) {
    margin-inline-start: 0.3ch;
    font-variant-numeric: tabular-nums;
  }

  /* FK-style solid black checkout button inside the drawer */
  .cart-drawer__summary .cart__checkout-button {
    background: var(--color-foreground);
    color: var(--color-background);
    border: 0;
  }

  .cart-drawer__summary .cart__checkout-button:hover {
    opacity: 0.9;
  }

  /* =========================================================================
     Unified Filippa K drawer: the wishlist panel is an absolute overlay stacked
     on top of the cart content inside the SAME cart dialog. The Cart/Wishlist
     tabs flip `data-active-tab` on the dialog, which crossfades between the two
     panels — the drawer never slides or closes. Overrides the standalone
     (fixed, sliding) .wishlist-drawer styles from sections/favorites-drawer. */
  .theme-drawer__dialog cart-drawer-component {
    /* Match the wishlist panel's transition EXACTLY (incl. visibility) so the
       crossfade is symmetric. Without the visibility transition the cart panel
       hid instantly on cart->wishlist (visibility:hidden isn't animated), which
       read as a flicker; transitioning visibility keeps it shown until the fade
       completes, like the wishlist panel does going the other way. */
    transition: opacity 0.25s var(--animation-easing, ease), visibility 0.25s;
  }
  .theme-drawer__dialog[data-active-tab='wishlist'] cart-drawer-component {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .theme-drawer__dialog .wishlist-drawer--unified {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s var(--animation-easing, ease), visibility 0.25s;
  }
  .theme-drawer__dialog[data-active-tab='wishlist'] .wishlist-drawer--unified {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .wishlist-drawer--unified .wishlist-drawer__overlay {
    display: none;
  }
  .wishlist-drawer--unified .wishlist-drawer__panel {
    position: absolute;
    inset: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    transform: none;
    transition: none;
  }
{% endstylesheet %}
