{%- doc -%}
  Renders the size-chart popup as a native <dialog> driven by dialog-component
  (assets/dialog.js) — the same pattern as the search modal. Opened from the
  "Size chart" link in the size variant option (snippets/variant-main-picker.liquid)
  via on:click="#{modal_id}/showDialog".

  @param {string} modal_id - Unique id; the trigger targets "#{modal_id}/showDialog".
  @param {string} [content] - Rich-text HTML from the per-product custom.size_chart metafield.
  @param {object} [page] - Fallback size-guide page (settings.size_chart_page) used when no metafield is set.

  @example
  {% render 'size-chart-modal', modal_id: id, content: metafield_value, page: settings.size_chart_page %}
{%- enddoc -%}

<dialog-component id="{{ modal_id }}" class="size-chart-modal">
  <dialog
    ref="dialog"
    class="size-chart-modal__content dialog-modal"
    on:click="/closeDialogOnClickOutside"
    on:keydown="/closeDialogOnEscapePress"
    aria-labelledby="{{ modal_id }}-heading"
    scroll-lock
  >
    <div class="size-chart-modal__header">
      <h2 id="{{ modal_id }}-heading" class="size-chart-modal__title">Size chart</h2>
      <button
        type="button"
        class="size-chart-modal__close"
        aria-label="{{ 'accessibility.close_dialog' | t }}"
        on:click="dialog-component/closeDialog"
      >
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
    </div>
    <div class="size-chart-modal__body rte">
      {%- if content != blank -%}
        <rte-formatter>{{ content }}</rte-formatter>
      {%- elsif page != blank -%}
        <rte-formatter>{{ page.content }}</rte-formatter>
      {%- endif -%}
    </div>
  </dialog>
</dialog-component>

{% stylesheet %}
  /* A native <dialog> is display:none when closed. The previous rule forced
     display:flex unconditionally, which overrode that and leaked the content
     inline (and out of the centered top layer). Keep layout props here but gate
     the actual `display` on [open] so it only shows when opened via showModal(). */
  .size-chart-modal__content {
    padding: 0;
    flex-direction: column;
    color: var(--color-foreground);
    background: var(--color-background);
    border: 0;
    /* Center the modal in the viewport: fixed + inset:0 + margin:auto centers both
       axes; fit-content height keeps it a centered box instead of stretching top-to-
       bottom. (Without position:fixed, margin:auto only centered it horizontally.) */
    position: fixed;
    inset: 0;
    margin: auto;
    height: fit-content;
  }

  .size-chart-modal__content[open] {
    display: flex;
  }

  /* Horizon's shared .dialog-modal slides in from the top via @keyframes
     elementSlideInTop, which animates `margin-top: 0` (forwards) and so overrides
     the `margin: auto` that centers this modal — pinning it to the top. Override
     that animation with a centered fade. Higher specificity (dialog.<class>[open])
     beats .dialog-modal[open]; .dialog-closing comes after [open] to win on close. */
  dialog.size-chart-modal__content[open] {
    animation: scm-fade-in 0.25s var(--animation-easing, ease) both;
  }
  dialog.size-chart-modal__content.dialog-closing {
    animation: scm-fade-out 0.2s var(--animation-easing, ease) both;
  }
  @keyframes scm-fade-in {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes scm-fade-out {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(6px); }
  }

  .size-chart-modal__header {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-md);
    padding: var(--padding-lg) var(--padding-lg) var(--padding-md);
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .size-chart-modal__title {
    margin: 0;
    font-size: var(--font-size--md);
  }

  .size-chart-modal__close {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    width: var(--minimum-touch-target);
    height: var(--minimum-touch-target);
    margin-inline-end: calc(-1 * var(--padding-sm));
    padding: 0;
    border: 0;
    background: none;
    color: inherit;
    cursor: pointer;
  }

  .size-chart-modal__close svg {
    width: var(--icon-size-md);
    height: var(--icon-size-md);
  }

  .size-chart-modal__body {
    flex: 1 1 auto;
    padding: var(--padding-md) var(--padding-lg) var(--padding-lg);
    overflow-y: auto;
  }

  /* Sensible defaults for a rich-text size table pasted into the metafield/page. */
  .size-chart-modal__body table {
    width: 100%;
    border-collapse: collapse;
  }

  .size-chart-modal__body :where(th, td) {
    padding: var(--padding-xs) var(--padding-sm);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    text-align: start;
  }

  .size-chart-modal__body :where(p, table):not(:last-child) {
    margin-block-end: var(--margin-md);
  }

  @media screen and (min-width: 750px) {
    .size-chart-modal__content {
      width: min(92vw, var(--normal-content-width));
      max-height: min(80dvh, 720px);
    }
  }

  @media screen and (max-width: 749px) {
    .size-chart-modal__content {
      width: 100vw;
      height: 100dvh;
      max-height: 100dvh;
    }
  }
{% endstylesheet %}
