span></div>\n</div>\n\n<script>\n  (function () {\n    var root = document.getElementById('lagni-td');\n    if (!root) return;\n    var target = root.querySelector('[data-lagni-delivery]');\n    if (!target) return;\n\n    // ---- inställningar ----\n    var cutoffH = 14, cutoffM = 0;   // daglig cutoff (24h)\n    var minDays = 1, maxDays = 2;    // leveransfönster i arbetsdagar\n    var skipWeekends = true;\n    var carrier = 'PostNord';\n\n    var days = ['söndag','måndag','tisdag','onsdag','torsdag','fredag','lördag'];\n    var months = ['januari','februari','mars','april','maj','juni','juli','augusti','september','oktober','november','december'];\n\n    function addBusinessDays(date, n, skip) {\n      var d = new Date(date), added = 0;\n      while (added < n) { d.setDate(d.getDate() + 1); if (!skip || (d.getDay() !== 0 && d.getDay() !== 6)) added++; }\n      return d;\n    }\n    function fmt(d) { return days[d.getDay()] + ' ' + d.getDate() + ' ' + months[d.getMonth()]; }\n    function humanize(ms) {\n      var t = Math.max(0, Math.round(ms / 60000)), h = Math.floor(t / 60), m = t % 60;\n      if (h > 0) return h + ' timmar' + (m > 0 ? ' ' + m + ' minuter' : '');\n      return m + ' minuter';\n    }\n    function range(base) {\n      var a = addBusinessDays(base, minDays, skipWeekends), b = addBusinessDays(base, maxDays, skipWeekends);\n      if (fmt(a) === fmt(b)) return 'För leverans <strong>' + fmt(a) + '</strong>';\n      return 'För leverans mellan <strong>' + fmt(a) + '</strong> och <strong>' + fmt(b) + '</strong>';\n    }\n    function render() {\n      var now = new Date(), cutoff = new Date(now);\n      cutoff.setHours(cutoffH, cutoffM, 0, 0);\n      var base = new Date(now); base.setHours(0, 0, 0, 0);\n      var html;\n      if (now < cutoff) {\n        html = 'Beställ inom <strong>' + humanize(cutoff - now) + '</strong>. ' + range(base) + ' med <span class=\"lagni-td__postnord\">' + carrier + '</span>.';\n      } else {\n        base.setDate(base.getDate() + 1);\n        html = 'Beställ idag. ' + range(base) + ' med <span class=\"lagni-td__postnord\">' + carrier + '</span>.';\n      }\n      target.innerHTML = html;\n    }\n    render();\n    setInterval(render, 30000);\n  })();\n</script>"
