            "custom_liquid_BEA7Kr": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<style>\n  .lagni-td { display:flex; flex-direction:column; gap:2px; width:100%; margin:8px 0; color:#1a1a1a; font-family:inherit; font-size:14px; }\n  .lagni-td__cards { display:grid; grid-template-columns:1fr 1fr; gap:2px; }\n  .lagni-td__card { background:#f5f5f5; border-radius:0; padding:12px; display:flex; flex-direction:column; gap:14px; }\n  .lagni-td__badges { display:flex; align-items:center; gap:8px; flex-wrap:wrap; min-height:12px; }\n  .lagni-td__pay { height:24px; width:auto; display:block; }\n  .lagni-td__plus { font-size:10px; font-weight:500; opacity:0.8; margin-inline-start:2px; }\n  .lagni-td__text { font-size:12px; line-height:1.35; font-weight:400; margin:0; }\n  .lagni-td__banner { background:#f5f5f5; border-radius:0; padding:12px; text-align:center; font-size:12px; line-height:1.5; font-weight:400; }\n  .lagni-td__banner strong { font-weight:700; }\n  .lagni-td__postnord { color:#005aa0; font-weight:700; white-space:nowrap; }\n  /* Mobil: behåll två kolumner, krymp padding/gap så korten får plats bredvid varandra. Banner-raden ligger alltid ensam, full bredd. */\n  @media screen and (max-width:749px){\n    .lagni-td__cards { gap:2px; }\n    .lagni-td__card { padding:14px; gap:10px; }\n    .lagni-td__badges { gap:6px; }\n    .lagni-td__pay { height:20px; }\n  }\n</style>\n\n<div class=\"lagni-td\" id=\"lagni-td\">\n  <div class=\"lagni-td__cards\">\n    <div class=\"lagni-td__card\">\n      <div class=\"lagni-td__badges\">\n        <svg class=\"lagni-td__pay\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" viewBox=\"0 0 38 24\" width=\"38\" height=\"24\" aria-labelledby=\"pi-klarna\" fill=\"none\"><title id=\"pi-klarna\">Klarna</title><rect width=\"38\" height=\"24\" rx=\"2\" fill=\"#FFA8CD\"></rect><rect x=\".5\" y=\".5\" width=\"37\" height=\"23\" rx=\"1.5\" stroke=\"#000\" stroke-opacity=\".07\"></rect><path d=\"M30.62 14.755c-.662 0-1.179-.554-1.179-1.226 0-.673.517-1.226 1.18-1.226.663 0 1.18.553 1.18 1.